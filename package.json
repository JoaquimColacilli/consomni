{
  "name": "consomni",
  "version": "1.9.9",
  "description": "Consomni — consola + omni · un ojo que lo ve todo. Monitor en tiempo real de sesiones de Claude Code, 100% local.",
  "author": "Joaquim Colacilli",
  "license": "UNLICENSED",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -w -p tsconfig.json",
    "start": "electron .",
    "dev": "tsc -p tsconfig.json && electron .",
    "dist": "npm run build && electron-builder --win",
    "pack": "npm run build && electron-builder --win --dir",
    "release": "npm run build && electron-builder --win --publish always"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "chokidar": "^3.6.0",
    "electron-updater": "^6.8.9",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "electron": "^29.4.6",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2"
  }
}
